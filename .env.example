# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GIGACHAT_AUTH_KEY: Base64-encoded Basic auth credentials for GigaChat OAuth.
# Используется прокси-сервером (server.ts) для получения access_token.
# Получить ключ можно в личном кабинете developers.sber.ru.
GIGACHAT_AUTH_KEY="MY_GIGACHAT_AUTH_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP credentials for sending contact form emails via Yandex Mail.
# SMTP_USER: your full Yandex address, e.g. ruslan-39kld@yandex.ru
# SMTP_PASS: app password (create at https://id.yandex.ru/security/app-passwords)
SMTP_USER="ruslan-39kld@yandex.ru"
SMTP_PASS="MY_YANDEX_APP_PASSWORD"
